    <script type="text/javascript">
        function jacct() {
            var jAcct = $("input[id='joint_account_radio']:checked").length > 0;
            if (jAcct) {
                var jAcctV = $("input[id='joint_account_radio']:checked").val();
                if (jAcctV == 1) {
                    $('#joint_account').show();
                } else {
                    $('#joint_account').hide();
                }
            }

        }
    </script>
